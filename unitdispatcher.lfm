      object Label27: TLabel
        Left = 45
        Height = 180
        Top = 32
        Width = 289
        Caption = 'É uma interface gráfica (desenvolvida em Lazarus) que '#13#10'funciona como o painel de controlo central de uma '#13#10'fábrica. Permite ao utilizador gerir o inventário '#13#10'("Stock Inicial"), criar ordens de fabrico ("Plano '#13#10'Semanal") e monitorizar os eventos do sistema '#13#10'através de um terminal de registos ("Logger"). '#13#10'Atualmente, a lógica de dados e controlo acontece '#13#10'apenas na memória do próprio programa.'#13#10#13#10'Após o seu desenvolvimento completo o software vai '#13#10'evoluir para uma aplicação multinível completa, '#13#10'interligando a gestão de topo com o chão de fábrica.'
        Font.CharSet = ANSI_CHARSET
        Font.Pitch = fpVariable
        Font.Quality = fqDraft
        ParentFont = False
      end
    end
