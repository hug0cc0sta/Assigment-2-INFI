          object Label31: TLabel
            Left = 13
            Height = 330
            Top = 13
            Width = 520
            Caption = 'Painel da Produção é o lugar do sistema onde é possível Inicializar stock, '#13#10'fazer e executar o plano semanal,  e observar o que está a acontecer no chão de fábrica'#13#10#13#10'Sendo assim, o Painel da Produção está dividido em 3 partes principais:'#13#10#13#10'1)No painel do stock inicial é possível inicializar o stock'#13#10'existente inicialmente na fábrica. '#13#10'Existem 9 peças diferentes, correspondendo a 3 tipos '#13#10'de 3 cores cada - Azul, Verde e Cinza'#13#10#13#10'Só é possível inicializar o stock uma vez e não é '#13#10'possível inicializar mais que uma soma de 6 '#13#10'peças de qualquer tipo de uma vez.'#13#10#13#10'2)No painel de plano de produção é possível adicionar várias tarefas de produção a serem '#13#10'executadas durante a semana. Cada pedido tem de ser feito individualmente, e se, '#13#10'eventualmente, for preciso retirar algum, é possível selecionando a linha (sendo possível selecionar'#13#10'mais do que uma linha) do pedido e depois carregando no botão limpar.'#13#10'Tendo todas as tarefas no plano podemos executar o plano, usando o botão correspondente.'#13#10#13#10#13#10'3)É uma janela onde é possível observar aquilo que se está a passar na fábrica, com vários logs'
            Color = clGray
            Font.CharSet = ANSI_CHARSET
            Font.Pitch = fpVariable
            Font.Quality = fqDraft
            ParentColor = False
            ParentFont = False
          end
